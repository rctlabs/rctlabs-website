# rctlabs-website — Environment Variables
# =========================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local to version control.
#
# For Vercel deployment:
#   Dashboard → rctlabs-website → Settings → Environment Variables
#   Set NEXT_PUBLIC_API_URL = https://api.rctlabs.co (Production)
#   Set NEXT_PUBLIC_API_URL = http://localhost:8000  (Preview/Development)

# Supabase (Auth)
# Production:  https://<project-ref>.supabase.co
# Local dev:   use the same hosted URL unless self-hosting
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Auth behavior flags
# true  = /admin, /owner, /monitor, /analytics, /test-console, /websocket require session+role
# false = fallback behavior (production still blocks internal paths)
REQUIRE_SESSION_AUTH=true

# Assistant routes auth gate
# true  = /api/chat, /api/analyze, /api/mirror require authenticated session
# false = public fallback behavior
REQUIRE_AUTH_FOR_ASSISTANT=false

# Backend API base URL
# Production:  https://api.rctlabs.co
# Local dev:   http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-only API base URL for route handlers/BFF
# Keeps backend hostname internal and separate from public browser config.
API_BASE_URL=http://localhost:8000

# Supabase Studio URL (server-only, for admin operations)
# Production: https://<project-ref>.supabase.co
STUDIO_URL=
